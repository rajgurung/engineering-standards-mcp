{
  "name": "claude-engineering-standards",
  "version": "0.1.0",
  "description": "MCP server that gives Claude Code your team's engineering standards — git, Rails, testing, deployment, code review, frontend",
  "type": "module",
  "bin": {
    "claude-engineering-standards": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/standards build/standards && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "claude",
    "claude-code",
    "engineering-standards",
    "rails",
    "code-review",
    "staff-engineer",
    "deployment",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
