{
  "name": "engineering-standards-mcp",
  "version": "0.1.0",
  "description": "Personal MCP server encoding engineering standards, git etiquette, and staff-engineer-level best practices",
  "type": "module",
  "bin": {
    "engineering-standards-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/standards build/standards && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "engineering-standards",
    "git-conventions",
    "code-review",
    "staff-engineer"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
